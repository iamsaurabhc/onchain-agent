# Phase D MCP server configuration.
# Preferred location: repo root `.env.local` (loaded automatically).
# Optional override: `packages/mcp-server/.env.local` (fills keys not set in root).
# Copy this file to repo root as `.env.local` and fill in real values.

# JSON-RPC endpoint.
#   Amoy (Alchemy):  https://polygon-amoy.g.alchemy.com/v2/<API_KEY>
#   Amoy (public):   https://rpc-amoy.polygon.technology
#   Local anvil:     http://127.0.0.1:8545
RPC_URL=

# Chain id. 80002 = Polygon Amoy (default), 31337 = local anvil.
CHAIN_ID=80002

# Deployed AnchorRegistry contract address (from `forge create`).
ANCHOR_REGISTRY_ADDRESS=

# Anchorer signing key. Required only for anchor_hash (writes); omit for read/verify-only.
# Use a dedicated test wallet.
ANCHORER_PRIVATE_KEY=

# Minimum confirmations before a record is treated as final. Amoy default: 64. For prod, use 5
CONFIRMATIONS=64

# Max blocks per eth_getLogs request (verify_by_log). Providers cap this:
# Alchemy free tier = 10. The scan chunks to stay within the limit. Default: 500.
LOG_SCAN_MAX_RANGE=500

# Total blocks back from head to scan for logs; 0 = back to genesis (chunked,
# early-exit on first match). Set a finite window to bound not-found scans.
LOG_SCAN_LOOKBACK=0
