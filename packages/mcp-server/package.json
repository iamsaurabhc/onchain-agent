{
  "name": "@onchain-agent/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Phase D MCP server: anchoring & verification exposed as Mastra MCP tools.",
  "bin": {
    "onchain-anchor-mcp": "src/server.ts"
  },
  "scripts": {
    "start": "tsx src/server.ts",
