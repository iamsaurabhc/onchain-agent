# Phase F A2A agent configuration.
# Preferred location: repo root `.env.local` (loaded automatically).
# Copy this file to repo root as `.env.local` and fill in real values.

# --- Chain / MCP (same as Phase D) ---
RPC_URL=
CHAIN_ID=80002
ANCHOR_REGISTRY_ADDRESS=
ANCHORER_PRIVATE_KEY=
CONFIRMATIONS=64

# --- LLM (OpenRouter via AI SDK) ---
OPENROUTER_API_KEY=

# Model ids (swap without code changes). Defaults are free tool-calling models.
A2A_MODEL_LARGE=nvidia/nemotron-3-ultra-550b-a55b:free
A2A_MODEL_SMALL=openai/gpt-oss-20b:free

# --- MCP subprocess (prod path: spawn Phase D stdio server) ---
A2A_MCP_COMMAND=tsx
A2A_MCP_ARGS=packages/mcp-server/src/server.ts

# --- A2A HTTP server ---
A2A_PORT=4111
